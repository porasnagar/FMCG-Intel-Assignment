# FMCG Intelligence AI — Environment Variables
# Copy this file to .env and fill in your keys

# ─── AI ───────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://build.nvidia.com/nim (free tier available)
# Gives access to Llama 3.1 405B, Mistral, and 100+ models
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# ─── Sources ──────────────────────────────────────────────────────────────────
# Get from: https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Infrastructure ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fmcg_user:fmcg_password@localhost:5432/fmcg_db
REDIS_URL=redis://localhost:6379/0

# ─── Pipeline Security ────────────────────────────────────────────────────────
# Secret key to protect the /api/pipeline/run endpoint.
# Must match the PIPELINE_SECRET in GitHub Actions secrets.
PIPELINE_SECRET=your_random_secret_here
